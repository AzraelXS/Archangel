## Project
COMPOSE_PROJECT_NAME=archangel-collector

## Version pins
STACK_VERSION=8.15.3

## Local Elasticsearch (this collector's durable backlog)
ES_PORT=9201
ES_MEM_LIMIT=1073741824
ELASTIC_PASSWORD=ChangeMe_Collector_Elastic_2026!
CLUSTER_NAME=archangel-collector-cluster
LICENSE=basic

## Redis / Celery
REDIS_PORT=6380

## Listeners
SNMP_TRAP_PORT=1162
SMTP_LISTEN_PORT=1025
SYSLOG_UDP_PORT=5514
SYSLOG_TCP_PORT=5514

## Cloud sync
## nginx on the cloud stack currently terminates plain HTTP only (no cert
## configured yet) -- point this at the cloud VM's address, port 80.
CLOUD_API_URL=http://CHANGE_ME_CLOUD_HOST/api/v1
TENANT_API_KEY=ChangeMe_Tenant_Api_Key
COLLECTOR_NAME=collector-01
